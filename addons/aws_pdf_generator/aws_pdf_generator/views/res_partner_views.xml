<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_aws_pdf" model="ir.ui.view">
        <field name="name">res.partner.form.aws.pdf</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_generate_aws_pdf" 
                            type="object" 
                            string="Generar PDF (Nube AWS)" 
                            class="oe_highlight" 
                            icon="fa-cloud"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
